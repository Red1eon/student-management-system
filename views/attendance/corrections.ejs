<div class="space-y-6 animate-fade-in">
  <div class="flex items-center justify-between">
    <h2 class="text-2xl font-bold text-gray-800"><%= __('attendance_corrections') %></h2>
    <form method="GET" action="/attendance/corrections" class="flex gap-2">
      <select name="status" class="border border-gray-300 rounded-lg px-3 py-2">
        <option value=""><%= __('all') %></option>
        <% ['pending','approved','rejected'].forEach((s) => { %>
          <option value="<%= s %>" <%= query?.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
      <button class="bg-gray-800 text-white rounded-lg px-4 py-2 hover:bg-gray-900"><%= __('filter') %></button>
    </form>
  </div>

  <% if (query?.success) { %><div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-green-700"><%= query.success %></div><% } %>
  <% if (query?.error) { %><div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700"><%= query.error %></div><% } %>

  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('student') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('date') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('current_requested') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('reason') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('status_label') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('action') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (Array.isArray(corrections) && corrections.length > 0) { %>
          <% corrections.forEach((c) => { %>
            <tr>
              <td class="px-6 py-4 text-sm text-gray-800"><%= c.student_name %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= c.attendance_date %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= c.current_status %> -> <%= c.requested_status %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= c.reason %></td>
              <td class="px-6 py-4 text-sm capitalize"><%= c.status %></td>
              <td class="px-6 py-4 text-sm">
                <% if (c.status === 'pending' && ['admin','staff','teacher'].includes(role)) { %>
                  <form method="POST" action="/attendance/corrections/<%= c.correction_id %>/review" class="flex gap-2">
                    <input name="review_comment" placeholder="Comment" class="border border-gray-300 rounded px-2 py-1 text-xs">
                    <button name="decision" value="approve" class="bg-green-600 text-white rounded px-2 py-1 text-xs"><%= __('approve') %></button>
                    <button name="decision" value="reject" class="bg-red-600 text-white rounded px-2 py-1 text-xs"><%= __('reject') %></button>
                  </form>
                <% } else { %>
                  <span class="text-gray-400">-</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500"><%= __('no_correction_requests') %></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

