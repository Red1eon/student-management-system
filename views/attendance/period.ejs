<div class="max-w-5xl mx-auto animate-fade-in space-y-6">
  <h2 class="text-2xl font-bold text-gray-800">Period Attendance</h2>
  <% if (query && query.success) { %><div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-green-700"><%= query.success %></div><% } %>
  <% if (query && query.error) { %><div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700"><%= query.error %></div><% } %>

  <form action="/attendance/period" method="GET" class="bg-white rounded-xl shadow p-4 grid grid-cols-1 md:grid-cols-4 gap-3">
    <select name="class_id" required class="border border-gray-300 rounded-lg px-3 py-2">
      <option value="">Select Class</option>
      <% (classes || []).forEach((c) => { %>
        <option value="<%= c.class_id %>" <%= String(selectedClass || '') === String(c.class_id) ? 'selected' : '' %>><%= c.class_name %> <%= c.section || '' %></option>
      <% }) %>
    </select>
    <input type="date" name="date" value="<%= selectedDate || new Date().toISOString().slice(0,10) %>" required class="border border-gray-300 rounded-lg px-3 py-2">
    <input name="period" value="<%= selectedPeriod || 'P1' %>" placeholder="Period label (e.g., P1)" required class="border border-gray-300 rounded-lg px-3 py-2">
    <button class="bg-indigo-600 text-white rounded-lg px-4 py-2 hover:bg-indigo-700">Load</button>
  </form>

  <% if ((students || []).length > 0) { %>
    <form action="/attendance/period" method="POST" class="bg-white rounded-xl shadow-lg p-6 space-y-4">
      <input type="hidden" name="class_id" value="<%= selectedClass %>">
      <input type="hidden" name="date" value="<%= selectedDate %>">
      <input type="hidden" name="period_label" value="<%= selectedPeriod %>">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Subject (optional)</label>
        <select name="subject_id" class="border border-gray-300 rounded-lg px-3 py-2">
          <option value="">No subject</option>
          <% (subjects || []).forEach((s) => { %>
            <option value="<%= s.subject_id %>"><%= s.subject_name %> (<%= s.subject_code %>)</option>
          <% }) %>
        </select>
      </div>

      <div class="space-y-2">
        <% students.forEach((s) => { const ex = (existing || []).find((e) => String(e.student_id) === String(s.student_id)); %>
          <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <div class="text-sm font-medium text-gray-800"><%= s.first_name %> <%= s.last_name %></div>
            <div class="flex items-center gap-2">
              <% ['present','absent','late','excused'].forEach((st) => { %>
                <label class="cursor-pointer">
                  <input type="radio" name="attendance[<%= s.student_id %>][status]" value="<%= st %>" <%= ex?.status === st ? 'checked' : (st === 'present' ? 'checked' : '') %> class="sr-only peer">
                  <span class="px-2 py-1 text-xs rounded bg-gray-200 text-gray-700 peer-checked:bg-indigo-600 peer-checked:text-white"><%= st %></span>
                </label>
              <% }) %>
              <input name="attendance[<%= s.student_id %>][remarks]" value="<%= ex?.remarks || '' %>" placeholder="Remarks" class="border border-gray-300 rounded px-2 py-1 text-xs">
            </div>
          </div>
        <% }) %>
      </div>
      <div class="flex justify-end"><button class="bg-indigo-600 text-white rounded-lg px-4 py-2 hover:bg-indigo-700">Save Period Attendance</button></div>
    </form>
  <% } %>
</div>

