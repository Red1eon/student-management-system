<div class="space-y-6 animate-fade-in">
  <a href="/students/<%= student.student_id %>" class="text-blue-600 hover:underline inline-block">
    <i class="fas fa-arrow-left mr-2"></i> Back to Student
  </a>

  <h2 class="text-2xl font-bold text-gray-800">Student Results</h2>
  <p class="text-sm text-gray-500"><%= student.first_name %> <%= student.last_name %> | <%= student.admission_number %></p>

  <% const totalScored = (results || []).reduce((sum, r) => sum + Number(r.marks_obtained || 0), 0); %>
  <% const totalOutOf = (results || []).reduce((sum, r) => sum + Number(r.total_marks || 0), 0); %>
  <% const percentage = totalOutOf > 0 ? ((totalScored / totalOutOf) * 100).toFixed(2) : '0.00'; %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-blue-50 rounded-lg p-4"><p class="text-xs text-blue-700">Total Scored</p><p class="text-2xl font-bold text-blue-800"><%= totalScored %></p></div>
    <div class="bg-gray-100 rounded-lg p-4"><p class="text-xs text-gray-700">Total Marks</p><p class="text-2xl font-bold text-gray-800"><%= totalOutOf %></p></div>
    <div class="bg-green-50 rounded-lg p-4"><p class="text-xs text-green-700">Percentage</p><p class="text-2xl font-bold text-green-800"><%= percentage %>%</p></div>
  </div>

  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Exam</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Marks</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Grade</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Remarks</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (Array.isArray(results) && results.length > 0) { %>
          <% results.forEach((result) => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-800"><%= result.exam_name %> <span class="text-gray-500">(<%= result.exam_type || '-' %>)</span></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= result.subject_name || '-' %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= result.exam_date || '-' %></td>
              <td class="px-6 py-4 text-sm text-gray-800"><%= result.marks_obtained %> / <%= result.total_marks %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= result.grade || '-' %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= result.remarks || '-' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">No exam results available</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
