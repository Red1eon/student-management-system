<div class="space-y-6 animate-fade-in">
  <div class="flex items-center justify-between">
    <h2 class="text-2xl font-bold text-gray-800"><%= canManageLibrary ? 'Library Books' : 'Available Books' %></h2>
    <% if (canManageLibrary) { %>
      <a href="/library/books/add" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
        <i class="fas fa-plus mr-2"></i>Add Book
      </a>
    <% } %>
  </div>

  <% if (!canManageLibrary) { %>
    <p class="text-gray-600"><%= __('you_can_request_available_books') %></p>
  <% } %>

  <% if (books.length === 0) { %>
    <div class="bg-white rounded-xl shadow-lg p-6 text-gray-500"><%= __('no_books_found') %></div>
  <% } else { %>
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('title') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('author') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('category') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('available') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('action') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% books.forEach((book) => { %>
            <% const hasPendingRequest = !canManageLibrary && userRequests.some((r) => r.book_id === book.book_id && r.status === 'pending'); %>
            <tr>
              <td class="px-6 py-4 font-medium text-gray-800"><%= book.title %></td>
              <td class="px-6 py-4 text-gray-600"><%= book.author %></td>
              <td class="px-6 py-4 text-gray-600"><%= book.category || '-' %></td>
              <td class="px-6 py-4 text-gray-600"><%= book.available_quantity %> / <%= book.quantity %></td>
              <td class="px-6 py-4">
                <% if (canManageLibrary) { %>
                  <a href="/library/issue" class="text-blue-600 hover:underline"><%= __('issue') %></a>
                <% } else if (book.available_quantity > 0 && !hasPendingRequest) { %>
                  <form action="/library/request" method="POST">
                    <input type="hidden" name="book_id" value="<%= book.book_id %>">
                    <button type="submit" class="bg-purple-600 text-white px-3 py-1 rounded hover:bg-purple-700">
                      Request Book
                    </button>
                  </form>
                <% } else if (hasPendingRequest) { %>
                  <span class="text-yellow-700 bg-yellow-100 px-2 py-1 rounded text-xs"><%= __('pending_request') %></span>
                <% } else { %>
                  <span class="text-red-700 bg-red-100 px-2 py-1 rounded text-xs"><%= __('unavailable') %></span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
