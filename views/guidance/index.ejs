<div class="space-y-6 animate-fade-in">
  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <h2 class="text-2xl font-bold text-gray-800">Guidance Records</h2>
  </div>

  <% if (query && query.success) { %>
    <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-green-700"><%= query.success %></div>
  <% } %>
  <% if (query && query.error) { %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700"><%= query.error %></div>
  <% } %>

  <% const currentRole = (user && (user.userType || user.user_type)) || ''; %>
  <% if (currentRole !== 'student') { %>
    <form method="GET" action="/guidance" class="bg-white rounded-xl shadow p-4 grid grid-cols-1 md:grid-cols-3 gap-3">
      <select name="class_id" class="border border-gray-300 rounded-lg px-3 py-2">
        <option value="">All Classes</option>
        <% (classes || []).forEach((c) => { %>
          <option value="<%= c.class_id %>" <%= String(filters?.class_id || '') === String(c.class_id) ? 'selected' : '' %>><%= c.class_name %> <%= c.section || '' %></option>
        <% }) %>
      </select>
      <div></div>
      <button class="bg-gray-800 text-white rounded-lg px-4 py-2 hover:bg-gray-900">Filter</button>
    </form>
  <% } %>

  <% if (canCreate) { %>
    <form method="POST" action="/guidance" class="bg-white rounded-xl shadow-lg p-6 space-y-4">
      <h3 class="font-semibold text-gray-800">Create Guidance Record</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm text-gray-700 mb-1">Student</label>
          <select name="student_id" required class="w-full border border-gray-300 rounded-lg px-3 py-2">
            <option value="">Select student</option>
            <% (students || []).forEach((s) => { %>
              <option value="<%= s.student_id %>"><%= s.first_name %> <%= s.last_name %> (<%= s.admission_number %>)</option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm text-gray-700 mb-1">Date</label>
          <input type="date" name="guidance_date" value="<%= new Date().toISOString().slice(0, 10) %>" required class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm text-gray-700 mb-1">Category</label>
          <select name="category" class="w-full border border-gray-300 rounded-lg px-3 py-2">
            <% ['academic','behavior','career','attendance','wellbeing','other'].forEach((category) => { %>
              <option value="<%= category %>"><%= category[0].toUpperCase() + category.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div></div>
        <div class="md:col-span-2">
          <label class="block text-sm text-gray-700 mb-1">Notes</label>
          <textarea name="notes" rows="4" required class="w-full border border-gray-300 rounded-lg px-3 py-2"></textarea>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm text-gray-700 mb-1">Follow-up Action</label>
          <textarea name="follow_up" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2"></textarea>
        </div>
      </div>
      <div class="flex justify-end">
        <button class="bg-blue-600 text-white rounded-lg px-4 py-2 hover:bg-blue-700">Save Record</button>
      </div>
    </form>
  <% } %>

  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Student</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Notes</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Follow-up</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (Array.isArray(records) && records.length > 0) { %>
          <% records.forEach((r) => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-700"><%= r.guidance_date %></td>
              <td class="px-6 py-4 text-sm text-gray-800">
                <a href="/guidance/student/<%= r.student_id %>" class="text-blue-600 hover:text-blue-800"><%= r.student_name %></a>
                <div class="text-xs text-gray-500"><%= r.class_name || '' %> <%= r.section || '' %></div>
              </td>
              <td class="px-6 py-4 text-sm capitalize text-gray-700"><%= r.category %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= r.notes %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= r.follow_up || '-' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">No guidance records found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
