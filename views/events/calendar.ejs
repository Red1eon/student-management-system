<div class="space-y-6 animate-fade-in">
  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <h2 class="text-2xl font-bold text-gray-800">Event Calendar</h2>
    <div class="flex items-center gap-3">
      <% if (canManageEvents) { %>
        <a href="/events/create" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">Create Event</a>
      <% } %>
      <a href="/events" class="text-blue-600 hover:underline">Back to Events</a>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow p-4 border-l-4 <%= schoolStatus.tomorrow.isSchoolOpen ? 'border-green-500' : 'border-red-500' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Japan School Notice</p>
    <p class="text-lg font-semibold text-gray-800"><%= schoolStatus.tomorrow.isSchoolOpen ? 'School Open Tomorrow' : 'Tomorrow is Holiday / Closed' %></p>
    <p class="text-sm text-gray-500"><%= schoolStatus.tomorrow.date %> - <%= schoolStatus.tomorrow.label %></p>
  </div>

  <form method="GET" action="/events/calendar" class="bg-white rounded-xl shadow p-4 grid grid-cols-1 md:grid-cols-3 gap-3">
    <input type="number" min="1" max="12" name="month" value="<%= month %>" placeholder="Month" class="border border-gray-300 rounded-lg px-3 py-2">
    <input type="number" min="2000" max="2100" name="year" value="<%= year %>" placeholder="Year" class="border border-gray-300 rounded-lg px-3 py-2">
    <button class="bg-blue-600 text-white rounded-lg px-4 py-2 hover:bg-blue-700">Load</button>
  </form>

  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Event</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (Array.isArray(events) && events.length > 0) { %>
          <% events.forEach((event) => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-600">
                <div><%= event.start_date || 'N/A' %></div>
                <div class="text-xs text-gray-500">to <%= event.end_date || 'N/A' %></div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-800"><%= event.event_name %></td>
              <td class="px-6 py-4 text-sm text-gray-600 capitalize"><%= event.event_type || 'general' %></td>
              <td class="px-6 py-4 text-sm"><a href="/events/<%= event.event_id %>" class="text-blue-600 hover:text-blue-800">View</a></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="4" class="px-6 py-8 text-center text-gray-500">No events for this period</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
