<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | School Management System</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">
    <div class="text-center">
        <h1 class="text-6xl font-bold text-gray-300 mb-4">Error</h1>
        <h2 class="text-2xl font-semibold text-gray-800 mb-2">Register</h2>
        <p class="text-gray-600 mb-6"><%= typeof message !== 'undefined' ? message : 'Something went wrong' %></p>
        <a href="/dashboard" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Go to Dashboard</a>
    </div>
</body>
</html>