<div class="min-h-screen flex items-center justify-center bg-gray-50">
    <div class="text-center max-w-md px-4">
        <h1 class="text-6xl font-bold text-red-300 mb-4"><i class="fas fa-exclamation-triangle"></i></h1>
        <h2 class="text-2xl font-semibold text-gray-800 mb-2">Error</h2>
        <p class="text-gray-600 mb-6"><%= message %></p>
        <a href="<%= dashboardPath || '/dashboard' %>" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Go to Dashboard</a>
    </div>
</div>
