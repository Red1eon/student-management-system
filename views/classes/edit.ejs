<div class="max-w-2xl mx-auto animate-fade-in">
  <div class="bg-white rounded-xl shadow-lg p-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-6"><%= __('edit_class') %></h2>

    <% if (locals.error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= error %></div>
    <% } %>

    <form action="/classes/<%= classData.class_id %>/edit" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('class_name') %> *</label>
          <input type="text" name="class_name" value="<%= classData.class_name %>" required class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('section') %></label>
          <input type="text" name="section" value="<%= classData.section || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('class_code') %> *</label>
          <input type="text" name="class_code" value="<%= classData.class_code %>" required class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('academic_year') %> *</label>
          <input type="text" name="academic_year" value="<%= classData.academic_year %>" required class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('course_type') %></label>
          <select name="course_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
            <% const selectedCourseId = String(classData.course_id || ''); %>
            <option value=""><%= __('select_course') %></option>
            <% if (Array.isArray(courses) && courses.length > 0) { %>
              <% courses.forEach((course) => { %>
                <option value="<%= course.course_id %>" <%= selectedCourseId === String(course.course_id) ? 'selected' : '' %>>
                  <%= course.course_name %> (<%= (course.course_type || 'other').replace('_', ' ') %>)
                </option>
              <% }) %>
            <% } %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('course_fee') %></label>
          <input type="number" name="course_fee" min="0" step="0.01" value="<%= classData.course_fee || 0 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('payment_plan') %></label>
          <select name="fee_payment_plan" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
            <% const selectedPaymentPlan = classData.fee_payment_plan || 'one_time'; %>
            <option value="one_time" <%= selectedPaymentPlan === 'one_time' ? 'selected' : '' %>><%= __('one_time') %></option>
            <option value="monthly" <%= selectedPaymentPlan === 'monthly' ? 'selected' : '' %>><%= __('monthly') %></option>
            <option value="quarterly" <%= selectedPaymentPlan === 'quarterly' ? 'selected' : '' %>><%= __('quarterly') %></option>
            <option value="yearly" <%= selectedPaymentPlan === 'yearly' ? 'selected' : '' %>><%= __('yearly') %></option>
            <option value="installment" <%= selectedPaymentPlan === 'installment' ? 'selected' : '' %>><%= __('installment') %></option>
            <option value="flexible" <%= selectedPaymentPlan === 'flexible' ? 'selected' : '' %>><%= __('flexible') %></option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('class_teacher') %></label>
          <select name="class_teacher_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
            <option value=""><%= __('select_teacher') %></option>
            <% teachers.forEach((t) => { %>
              <option value="<%= t.user_id %>" <%= String(classData.class_teacher_id || '') === String(t.user_id) ? 'selected' : '' %>>
                <%= t.first_name %> <%= t.last_name %>
              </option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('capacity') %></label>
          <input type="number" name="capacity" value="<%= classData.capacity || 30 %>" min="1" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('room_number') %></label>
        <input type="text" name="room_number" value="<%= classData.room_number || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
      </div>

      <div class="flex justify-end gap-3">
        <a href="/classes" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50"><%= __('cancel') %></a>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700"><%= __('update_class') %></button>
      </div>
    </form>
  </div>
</div>
