<h1 class="text-3xl font-bold mb-6"><%= __('welcome') %>, <%= user.first_name %>!</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-blue-500">
    <p class="text-gray-500"><%= __('attendance') %></p>
    <p class="text-3xl font-bold"><%= stats.attendance_percentage %>%</p>
  </div>
  <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-green-500">
    <p class="text-gray-500"><%= __('class') %></p>
    <p class="text-3xl font-bold"><%= student?.class_name || __('na') %></p>
  </div>
  <div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-purple-500">
    <p class="text-gray-500"><%= __('roll_number') %></p>
    <p class="text-3xl font-bold"><%= student?.roll_number || __('na') %></p>
  </div>
</div>

<div class="bg-white p-6 rounded-xl shadow-lg border-l-4 border-amber-500 mb-8">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-gray-500">Course Fee</p>
      <p class="text-2xl font-bold text-gray-800">$<%= Number(feeSummary?.total || 0).toFixed(2) %></p>
      <p class="text-sm text-gray-500 mt-1">
        Paid: $<%= Number(feeSummary?.paid || 0).toFixed(2) %> | Left: $<%= Number(feeSummary?.balance || 0).toFixed(2) %>
      </p>
      <p class="text-sm text-gray-500 mt-1">
        Deadline: <%= feeSummary?.next_due_date || 'Not set' %>
      </p>
    </div>
    <a href="/student/my-fees" class="text-sm text-blue-600 hover:underline">View fee details</a>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <a href="/student/my-attendance" class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
    <i class="fas fa-clipboard-check text-3xl text-blue-600 mb-4"></i>
    <h3 class="font-bold text-lg"><%= __('view_attendance') %></h3>
    <p class="text-gray-500"><%= __('check_monthly_attendance') %></p>
  </a>
  <a href="/student/my-results" class="bg-white p-6 rounded-xl shadow hover:shadow-lg transition">
    <i class="fas fa-file-alt text-3xl text-green-600 mb-4"></i>
    <h3 class="font-bold text-lg"><%= __('view_results') %></h3>
    <p class="text-gray-500"><%= __('check_exam_results') %></p>
  </a>
</div>

<div class="mt-6 bg-white p-6 rounded-xl shadow">
  <div class="flex items-center justify-between mb-4">
    <h3 class="font-bold text-lg">Recent Notifications</h3>
    <a href="/notifications" class="text-sm text-blue-600 hover:underline">View all</a>
  </div>
  <% if (recentNotifications && recentNotifications.length > 0) { %>
    <div class="space-y-3">
      <% recentNotifications.forEach((n) => { %>
        <div class="border rounded-lg p-3 <%= n.is_read ? 'bg-white' : 'bg-blue-50 border-blue-200' %>">
          <p class="font-semibold text-gray-800"><%= n.title %></p>
          <p class="text-sm text-gray-600"><%= n.message %></p>
          <p class="text-xs text-gray-400 mt-1"><%= new Date(n.sent_at).toLocaleString() %></p>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-sm text-gray-500">No notifications yet.</p>
  <% } %>
</div>
