<div class="max-w-6xl mx-auto animate-fade-in">
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="bg-gradient-to-r from-blue-500 to-purple-600 px-8 py-6 text-white">
            <div class="flex items-center space-x-4">
                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center text-3xl font-bold text-blue-600">
                    <%= student.first_name[0] %><%= student.last_name[0] %>
                </div>
                <div>
                    <h1 class="text-3xl font-bold"><%= student.first_name %> <%= student.last_name %></h1>
                    <p class="text-blue-100"><%= student.admission_number %> • <%= student.class_name %> <%= student.section %></p>
                </div>
            </div>
        </div>

        <div class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="md:col-span-2 space-y-6">
                    <div>
                        <h3 class="text-lg font-semibold text-gray-800 mb-3"><%= __('personal_information') %></h3>
                        <div class="grid grid-cols-2 gap-4 text-sm">
                            <div>
                                <span class="text-gray-500"><%= __('email') %>:</span>
                                <p class="font-medium"><%= student.email %></p>
                            </div>
                            <div>
                                <span class="text-gray-500"><%= __('phone') %>:</span>
                                <p class="font-medium"><%= student.phone || __('na') %></p>
                            </div>
                            <div>
                                <span class="text-gray-500"><%= __('date_of_birth') %>:</span>
                                <p class="font-medium"><%= student.date_of_birth || __('na') %></p>
                            </div>
                            <div>
                                <span class="text-gray-500"><%= __('gender') %>:</span>
                                <p class="font-medium"><%= student.gender || __('na') %></p>
                            </div>
                            <div class="col-span-2">
                                <span class="text-gray-500"><%= __('address') %>:</span>
                                <p class="font-medium"><%= student.address || __('na') %></p>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-lg font-semibold text-gray-800 mb-3"><%= __('emergency_contact') %></h3>
                        <div class="grid grid-cols-2 gap-4 text-sm">
                            <div>
                                <span class="text-gray-500"><%= __('name') %>:</span>
                                <p class="font-medium"><%= student.emergency_contact_name || __('na') %></p>
                            </div>
                            <div>
                                <span class="text-gray-500"><%= __('phone') %>:</span>
                                <p class="font-medium"><%= student.emergency_contact_phone || __('na') %></p>
                            </div>
                        </div>
                    </div>

                    <% if (student.medical_conditions) { %>
                    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                        <h3 class="text-sm font-semibold text-yellow-800 mb-1"><%= __('medical_conditions') %></h3>
                        <p class="text-sm text-yellow-700"><%= student.medical_conditions %></p>
                    </div>
                    <% } %>
                </div>

                <div class="space-y-6">
                    <div class="bg-gray-50 rounded-lg p-4">
                        <h3 class="text-sm font-semibold text-gray-700 mb-3"><%= __('this_month_attendance') %></h3>
                        <div class="space-y-2">
                            <% attendance.forEach(a => { %>
                            <div class="flex justify-between text-sm">
                                <span class="capitalize"><%= a.status %></span>
                                <span class="font-medium"><%= a.count %> <%= __('days') %></span>
                            </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="bg-gray-50 rounded-lg p-4">
                        <h3 class="text-sm font-semibold text-gray-700 mb-3"><%= __('fee_balance') %></h3>
                        <div class="text-2xl font-bold <%= fees.balance > 0 ? 'text-red-600' : 'text-green-600' %>">
                            $<%= fees.balance.toFixed(2) %>
                        </div>
                        <a href="/fees/student/<%= student.student_id %>" class="text-blue-600 text-sm hover:underline mt-2 inline-block"><%= __('view_details') %></a>
                    </div>

                    <div class="flex space-x-2">
                        <a href="/students/<%= student.student_id %>/edit" class="flex-1 bg-blue-600 text-white text-center py-2 rounded-lg hover:bg-blue-700"><%= __('edit') %></a>
                        <a href="/attendance/student/<%= student.student_id %>" class="flex-1 bg-gray-200 text-gray-800 text-center py-2 rounded-lg hover:bg-gray-300"><%= __('attendance') %></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
