<div class="space-y-6 animate-fade-in">
  <h2 class="text-2xl font-bold text-gray-800"><%= __('children_fees') %></h2>

  <form method="GET" action="/parent/fees" class="bg-white rounded-xl shadow p-4">
    <select name="student_id" class="px-3 py-2 border rounded-lg mr-3">
      <% children.forEach((c) => { %>
        <option value="<%= c.student_id %>" <%= String(selectedStudent) === String(c.student_id) ? 'selected' : '' %>>
          <%= c.first_name %> <%= c.last_name %>
        </option>
      <% }) %>
    </select>
    <button class="bg-blue-600 text-white rounded-lg px-4 py-2"><%= __('load') %></button>
  </form>

  <div class="bg-white rounded-xl shadow p-4">
    <p class="text-sm text-gray-500"><%= __('outstanding_balance') %></p>
    <p class="text-3xl font-bold text-red-600"><%= Number(balance || 0).toFixed(2) %></p>
  </div>

  <div class="bg-white rounded-xl shadow overflow-hidden">
    <div class="px-6 py-4 border-b font-semibold"><%= __('fee_structure') %></div>
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('fee') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('amount') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Payment Plan</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('due_date') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (!fees || fees.length === 0) { %>
          <tr><td colspan="4" class="px-6 py-4 text-center text-gray-500"><%= __('no_fee_records') %></td></tr>
        <% } else { %>
          <% fees.forEach((f) => { %>
            <tr>
              <td class="px-6 py-4"><%= f.fee_name %></td>
              <td class="px-6 py-4"><%= Number(f.amount || 0).toFixed(2) %></td>
              <td class="px-6 py-4 capitalize"><%= String(f.payment_plan || '-').replace('_', ' ') %></td>
              <td class="px-6 py-4"><%= f.due_date || '-' %></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="bg-white rounded-xl shadow overflow-hidden">
    <div class="px-6 py-4 border-b font-semibold"><%= __('payments') %></div>
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('date') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('fee') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('amount') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('status_label') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (!payments || payments.length === 0) { %>
          <tr><td colspan="4" class="px-6 py-4 text-center text-gray-500"><%= __('no_payments_recorded') %></td></tr>
        <% } else { %>
          <% payments.forEach((p) => { %>
            <tr>
              <td class="px-6 py-4"><%= p.payment_date %></td>
              <td class="px-6 py-4"><%= p.fee_name %></td>
              <td class="px-6 py-4"><%= Number(p.amount_paid || 0).toFixed(2) %></td>
              <td class="px-6 py-4 capitalize"><%= __('status.' + p.payment_status) %></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
