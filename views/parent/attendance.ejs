<div class="space-y-6 animate-fade-in">
  <h2 class="text-2xl font-bold text-gray-800"><%= __('children_attendance') %></h2>

  <form method="GET" action="/parent/attendance" class="bg-white rounded-xl shadow p-4 grid grid-cols-1 md:grid-cols-4 gap-4">
    <select name="student_id" class="px-3 py-2 border rounded-lg">
      <% children.forEach((c) => { %>
        <option value="<%= c.student_id %>" <%= String(selectedStudent) === String(c.student_id) ? 'selected' : '' %>>
          <%= c.first_name %> <%= c.last_name %>
        </option>
      <% }) %>
    </select>
    <input type="number" name="month" min="1" max="12" value="<%= month %>" class="px-3 py-2 border rounded-lg">
    <input type="number" name="year" min="2000" max="2100" value="<%= year %>" class="px-3 py-2 border rounded-lg">
    <button class="bg-blue-600 text-white rounded-lg px-4 py-2"><%= __('load') %></button>
  </form>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <% ['present', 'absent', 'late', 'excused'].forEach((key) => { 
      const item = (stats || []).find((s) => s.status === key);
    %>
      <div class="bg-white rounded-xl shadow p-4">
        <p class="text-xs uppercase text-gray-500"><%= __('status.' + key) %></p>
        <p class="text-2xl font-bold"><%= item ? item.count : 0 %></p>
      </div>
    <% }) %>
  </div>

  <div class="bg-white rounded-xl shadow overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('date') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('status_label') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('remarks') %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (!attendance || attendance.length === 0) { %>
          <tr><td colspan="3" class="px-6 py-4 text-center text-gray-500"><%= __('no_attendance_records') %></td></tr>
        <% } else { %>
          <% attendance.forEach((a) => { %>
            <tr>
              <td class="px-6 py-4"><%= a.date %></td>
              <td class="px-6 py-4 capitalize"><%= a.status %></td>
              <td class="px-6 py-4"><%= a.remarks || '-' %></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
