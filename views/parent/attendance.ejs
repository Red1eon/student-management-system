<div class="space-y-6 animate-fade-in">
  <h2 class="text-2xl font-bold text-gray-800"><%= __('children_attendance') %></h2>

  <form method="GET" action="/parent/attendance" class="bg-white rounded-xl shadow p-4 grid grid-cols-1 md:grid-cols-5 gap-4">
    <select name="student_id" class="px-3 py-2 border rounded-lg">
      <% children.forEach((c) => { %>
        <option value="<%= c.student_id %>" <%= String(selectedStudent) === String(c.student_id) ? 'selected' : '' %>>
          <%= c.first_name %> <%= c.last_name %>
        </option>
      <% }) %>
    </select>
    <select name="scope" class="px-3 py-2 border rounded-lg">
      <option value="month" <%= (scope || 'month') === 'month' ? 'selected' : '' %>>This Month</option>
      <option value="overall" <%= (scope || 'month') === 'overall' ? 'selected' : '' %>>Overall</option>
    </select>
    <input type="number" name="month" min="1" max="12" value="<%= month %>" class="px-3 py-2 border rounded-lg">
    <input type="number" name="year" min="2000" max="2100" value="<%= year %>" class="px-3 py-2 border rounded-lg">
    <button class="bg-blue-600 text-white rounded-lg px-4 py-2"><%= __('load') %></button>
  </form>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <% ['present', 'absent', 'late', 'excused'].forEach((key) => { 
      const item = (stats || []).find((s) => s.status === key);
    %>
      <div class="bg-white rounded-xl shadow p-4">
        <p class="text-xs uppercase text-gray-500"><%= __('status.' + key) %></p>
        <p class="text-2xl font-bold"><%= item ? item.count : 0 %></p>
      </div>
    <% }) %>
  </div>

  <div class="bg-white rounded-xl shadow p-4">
    <p class="text-xs uppercase text-gray-500">Attendance Rate</p>
    <p class="text-2xl font-bold text-gray-800"><%= summary?.attendance_rate || 0 %>%</p>
  </div>

  <div class="bg-white rounded-xl shadow p-4">
    <h3 class="font-semibold text-gray-800 mb-3">Last 6 Months Trend</h3>
    <div class="space-y-2">
      <% (trend || []).forEach((t) => { %>
        <div class="flex items-center gap-3">
          <div class="w-20 text-xs text-gray-500"><%= t.label %></div>
          <div class="flex-1 bg-gray-100 rounded h-3 overflow-hidden">
            <div class="h-3 <%= t.rate < 75 ? 'bg-red-500' : (t.rate < 85 ? 'bg-yellow-500' : 'bg-green-500') %>" style="width:<%= Math.max(0, Math.min(100, t.rate)) %>%"></div>
          </div>
          <div class="w-12 text-xs text-gray-700 text-right"><%= t.rate %>%</div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('date') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('status_label') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('remarks') %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Correction</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (!attendance || attendance.length === 0) { %>
          <tr><td colspan="4" class="px-6 py-4 text-center text-gray-500"><%= __('no_attendance_records') %></td></tr>
        <% } else { %>
          <% attendance.forEach((a) => { %>
            <tr>
              <td class="px-6 py-4"><%= a.date %></td>
              <td class="px-6 py-4 capitalize"><%= a.status %></td>
              <td class="px-6 py-4"><%= a.remarks || '-' %></td>
              <td class="px-6 py-4">
                <form method="POST" action="/attendance/corrections/request" class="flex items-center gap-2">
                  <input type="hidden" name="attendance_id" value="<%= a.attendance_id %>">
                  <input type="hidden" name="student_id" value="<%= selectedStudent %>">
                  <select name="requested_status" class="border border-gray-300 rounded px-2 py-1 text-xs">
                    <% ['present','absent','late','excused'].forEach((st) => { %>
                      <option value="<%= st %>" <%= a.status === st ? 'selected' : '' %>><%= st %></option>
                    <% }) %>
                  </select>
                  <input name="reason" placeholder="Reason" class="border border-gray-300 rounded px-2 py-1 text-xs">
                  <button class="bg-yellow-600 text-white rounded px-2 py-1 text-xs">Request</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
