<div class="max-w-5xl mx-auto animate-fade-in space-y-6">
  <div class="bg-white rounded-xl shadow-lg p-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Edit Course</h2>

    <% if (locals.error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= error %></div>
    <% } %>

    <form action="/courses/<%= course.course_id %>/edit" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Course Name *</label>
          <input type="text" name="course_name" required value="<%= course.course_name || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Course Code *</label>
          <input type="text" name="course_code" required value="<%= course.course_code || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Course Type</label>
          <% const selectedCourseType = course.course_type || 'other'; %>
          <select name="course_type" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
            <option value="certificate" <%= selectedCourseType === 'certificate' ? 'selected' : '' %>>Certificate</option>
            <option value="diploma" <%= selectedCourseType === 'diploma' ? 'selected' : '' %>>Diploma</option>
            <option value="degree" <%= selectedCourseType === 'degree' ? 'selected' : '' %>>Degree</option>
            <option value="short_course" <%= selectedCourseType === 'short_course' ? 'selected' : '' %>>Short Course</option>
            <option value="other" <%= selectedCourseType === 'other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fee Amount</label>
          <input type="number" name="fee_amount" min="0" step="0.01" value="<%= course.fee_amount || 0 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fee Payment Plan</label>
          <% const selectedPaymentPlan = course.fee_payment_plan || 'one_time'; %>
          <select name="fee_payment_plan" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
            <option value="one_time" <%= selectedPaymentPlan === 'one_time' ? 'selected' : '' %>>One Time</option>
            <option value="monthly" <%= selectedPaymentPlan === 'monthly' ? 'selected' : '' %>>Monthly</option>
            <option value="quarterly" <%= selectedPaymentPlan === 'quarterly' ? 'selected' : '' %>>Quarterly</option>
            <option value="yearly" <%= selectedPaymentPlan === 'yearly' ? 'selected' : '' %>>Yearly</option>
            <option value="installment" <%= selectedPaymentPlan === 'installment' ? 'selected' : '' %>>Installment</option>
            <option value="flexible" <%= selectedPaymentPlan === 'flexible' ? 'selected' : '' %>>Flexible</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">How Fee Is Paid (Description)</label>
        <textarea name="fee_payment_description" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg"><%= course.fee_payment_description || '' %></textarea>
      </div>

      <div>
        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
          <input type="checkbox" name="is_active" value="1" <%= course.is_active ? 'checked' : '' %>>
          Active course (visible to all users)
        </label>
      </div>

      <div class="flex justify-end gap-3">
        <a href="/courses" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</a>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Update Course</button>
      </div>
    </form>
  </div>

  <div class="bg-white rounded-xl shadow-lg p-8">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between mb-6">
      <div>
        <h3 class="text-xl font-bold text-gray-800">Fee Structure</h3>
        <p class="text-sm text-gray-500">Manage fee lines for classes linked to this course.</p>
      </div>
    </div>

    <% if (Array.isArray(courseClasses) && courseClasses.length > 0) { %>
      <div class="flex flex-wrap gap-2 mb-5">
        <% courseClasses.forEach((cls) => { %>
          <a href="/fees/add?class_id=<%= cls.class_id %>&academic_year=<%= encodeURIComponent(cls.academic_year || '') %>&fee_type=tuition&frequency=one-time&return_to=/courses/<%= course.course_id %>/edit" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm bg-blue-50 text-blue-700 hover:bg-blue-100">
            + Add Fee for <%= cls.class_name %> <%= cls.section || '' %> (<%= cls.academic_year || '-' %>)
          </a>
        <% }) %>
      </div>
    <% } %>

    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Fee Name</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Class</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Amount</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Deadline</th>
            <th class="px-4 py-3 text-left font-semibold text-gray-600">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% if (Array.isArray(courseFees) && courseFees.length > 0) { %>
            <% courseFees.forEach((fee) => { %>
              <tr>
                <td class="px-4 py-3 text-gray-800"><%= fee.fee_name %></td>
                <td class="px-4 py-3 text-gray-600"><%= fee.class_name || 'All Classes' %> <%= fee.section || '' %></td>
                <td class="px-4 py-3 text-gray-800">$<%= Number(fee.amount || 0).toFixed(2) %></td>
                <td class="px-4 py-3 <%= fee.due_date && fee.due_date < new Date().toISOString().split('T')[0] ? 'text-red-600 font-semibold' : 'text-gray-600' %>"><%= fee.due_date || '-' %></td>
                <td class="px-4 py-3">
                  <a href="/fees/structure/<%= fee.fee_id %>/edit?return_to=/courses/<%= course.course_id %>/edit" class="text-blue-600 hover:text-blue-800 font-medium">Edit</a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="px-4 py-8 text-center text-gray-500">No fee structure found for this course yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
