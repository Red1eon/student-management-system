<div class="max-w-3xl mx-auto animate-fade-in">
  <div class="bg-white rounded-xl shadow-lg p-8">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Add Course</h2>

    <% if (locals.error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= error %></div>
    <% } %>

    <form action="/courses/add" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Course Name *</label>
          <input type="text" name="course_name" required value="<%= (typeof formData !== 'undefined' && formData) ? (formData.course_name || '') : '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Course Code *</label>
          <input type="text" name="course_code" required value="<%= (typeof formData !== 'undefined' && formData) ? (formData.course_code || '') : '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Course Type</label>
          <% const selectedCourseType = (typeof formData !== 'undefined' && formData && formData.course_type) ? formData.course_type : 'other'; %>
          <select name="course_type" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
            <option value="certificate" <%= selectedCourseType === 'certificate' ? 'selected' : '' %>>Certificate</option>
            <option value="diploma" <%= selectedCourseType === 'diploma' ? 'selected' : '' %>>Diploma</option>
            <option value="degree" <%= selectedCourseType === 'degree' ? 'selected' : '' %>>Degree</option>
            <option value="short_course" <%= selectedCourseType === 'short_course' ? 'selected' : '' %>>Short Course</option>
            <option value="other" <%= selectedCourseType === 'other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fee Amount</label>
          <input type="number" name="fee_amount" min="0" step="0.01" value="<%= (typeof formData !== 'undefined' && formData && formData.fee_amount) ? formData.fee_amount : 0 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Fee Payment Plan</label>
          <% const selectedPaymentPlan = (typeof formData !== 'undefined' && formData && formData.fee_payment_plan) ? formData.fee_payment_plan : 'one_time'; %>
          <select name="fee_payment_plan" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
            <option value="one_time" <%= selectedPaymentPlan === 'one_time' ? 'selected' : '' %>>One Time</option>
            <option value="monthly" <%= selectedPaymentPlan === 'monthly' ? 'selected' : '' %>>Monthly</option>
            <option value="quarterly" <%= selectedPaymentPlan === 'quarterly' ? 'selected' : '' %>>Quarterly</option>
            <option value="yearly" <%= selectedPaymentPlan === 'yearly' ? 'selected' : '' %>>Yearly</option>
            <option value="installment" <%= selectedPaymentPlan === 'installment' ? 'selected' : '' %>>Installment</option>
            <option value="flexible" <%= selectedPaymentPlan === 'flexible' ? 'selected' : '' %>>Flexible</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">How Fee Is Paid (Description)</label>
        <textarea name="fee_payment_description" rows="4" placeholder="Example: 4 installments, first by admission and remaining monthly." class="w-full px-3 py-2 border border-gray-300 rounded-lg"><%= (typeof formData !== 'undefined' && formData) ? (formData.fee_payment_description || '') : '' %></textarea>
      </div>

      <div>
        <% const checked = (typeof formData === 'undefined' || !formData || formData.is_active) ? 'checked' : ''; %>
        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
          <input type="checkbox" name="is_active" value="1" <%= checked %>>
          Active course (visible to all users)
        </label>
      </div>

      <div class="flex justify-end gap-3">
        <a href="/courses" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</a>
        <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">Create Course</button>
      </div>
    </form>
  </div>
</div>
