<div class="space-y-6 animate-fade-in">
  <a href="/teachers" class="text-blue-600 hover:underline inline-block">
    <i class="fas fa-arrow-left mr-2"></i> <%= __('back_to_teachers') %>
  </a>

  <div class="bg-white rounded-xl shadow-lg p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-center">
      <div class="flex items-center gap-4">
        <% if (teacher.profile_picture) { %>
          <img src="<%= teacher.profile_picture %>" alt="<%= teacher.first_name %>" class="w-16 h-16 rounded-full object-cover border border-gray-200">
        <% } else { %>
          <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 font-bold text-xl">
            <%= teacher.first_name[0] %><%= teacher.last_name[0] %>
          </div>
        <% } %>
        <div>
        <p class="text-xs text-gray-500"><%= __('teacher') %></p>
        <p class="text-xl font-bold text-gray-800"><%= teacher.first_name %> <%= teacher.last_name %></p>
        <p class="text-sm text-gray-600"><%= teacher.email || '-' %></p>
        </div>
      </div>
      <div class="md:text-right">
        <p class="text-xs text-gray-500"><%= __('employee_number') %></p>
        <p class="font-semibold text-gray-800"><%= teacher.employee_number || '-' %></p>
        <p class="text-sm text-gray-600"><%= teacher.department_name || __('no_department') %></p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 bg-white rounded-xl shadow-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h3 class="font-semibold text-gray-800"><%= __('assigned_subjects') %></h3>
      </div>
      <table class="w-full">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('subject') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('class') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('academic_year') %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% if (Array.isArray(subjects) && subjects.length > 0) { %>
            <% subjects.forEach((s) => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm text-gray-800"><%= s.subject_name %> (<%= s.subject_code %>)</td>
                <td class="px-6 py-4 text-sm text-gray-600"><%= s.class_name %> <%= s.section || '' %></td>
                <td class="px-6 py-4 text-sm text-gray-600"><%= s.academic_year || '-' %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="3" class="px-6 py-8 text-center text-gray-500"><%= __('no_subjects_assigned') %></td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <form action="/teachers/<%= teacher.teacher_id %>/assign-subject" method="POST" class="bg-white rounded-xl shadow-lg p-5 space-y-4 h-fit">
      <h3 class="font-semibold text-gray-800"><%= __('assign_subject') %></h3>
      <div>
        <label class="block text-sm text-gray-700 mb-1"><%= __('subject') %></label>
        <select name="subject_id" required class="w-full border border-gray-300 rounded-lg px-3 py-2">
          <option value=""><%= __('select_subject') %></option>
          <% (allSubjects || []).forEach((subject) => { %>
            <option value="<%= subject.subject_id %>"><%= subject.subject_name %> (<%= subject.subject_code %>)</option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm text-gray-700 mb-1"><%= __('class') %></label>
        <select name="class_id" required class="w-full border border-gray-300 rounded-lg px-3 py-2">
          <option value=""><%= __('select_class') %></option>
          <% (classes || []).forEach((c) => { %>
            <option value="<%= c.class_id %>"><%= c.class_name %> <%= c.section || '' %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm text-gray-700 mb-1"><%= __('academic_year') %></label>
        <input name="academic_year" value="<%= new Date().getFullYear() %>" required class="w-full border border-gray-300 rounded-lg px-3 py-2">
      </div>
      <button class="w-full bg-blue-600 text-white rounded-lg px-4 py-2 hover:bg-blue-700"><%= __('assign') %></button>
    </form>
  </div>
</div>
