<div class="space-y-6 animate-fade-in">
    <div class="flex justify-between items-center">
        <h2 class="text-2xl font-bold text-gray-800"><%= __('teachers') %></h2>
        <a href="/teachers/add" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
            <i class="fas fa-plus mr-2"></i> <%= __('add_teacher') %>
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('teacher') %></th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('employee_number') %></th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('department') %></th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('actions') %></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                <% if (typeof teachers !== 'undefined' && teachers.length > 0) { %>
                    <% teachers.forEach(t => { %>
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4">
                            <div class="flex items-center">
                                <% if (t.profile_picture) { %>
                                    <img src="<%= t.profile_picture %>" alt="<%= t.first_name %>" class="w-10 h-10 rounded-full object-cover mr-3 border border-gray-200">
                                <% } else { %>
                                    <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 font-bold mr-3">
                                        <%= t.first_name[0] %><%= t.last_name[0] %>
                                    </div>
                                <% } %>
                                <div>
                                    <div class="font-medium text-gray-900"><%= t.first_name %> <%= t.last_name %></div>
                                    <div class="text-sm text-gray-500"><%= t.email %></div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-500"><%= t.employee_number %></td>
                        <td class="px-6 py-4 text-sm text-gray-500"><%= t.department_name || __('na') %></td>
                        <td class="px-6 py-4 text-sm font-medium">
                            <a href="/teachers/<%= t.teacher_id %>" class="text-blue-600 hover:text-blue-900 mr-3"><%= __('view') %></a>
                        </td>
                    </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-gray-500"><%= __('no_teachers_found') %></td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
