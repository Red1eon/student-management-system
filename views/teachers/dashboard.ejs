<div class="space-y-6 animate-fade-in">
    <div class="bg-white rounded-xl shadow-lg p-6 border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-800">
            <%= __('welcome') %>, <%= user.first_name %> <%= user.last_name %>
        </h2>
        <p class="text-sm text-gray-500 mt-1 capitalize"><%= __('role') %>: <%= user.user_type %></p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-blue-500">
            <p class="text-gray-500 text-sm"><%= __('my_classes') %></p>
            <h3 class="text-3xl font-bold text-gray-800"><%= stats.total_classes || 0 %></h3>
        </div>
        <div class="bg-white rounded-xl shadow-lg p-6 border-l-4 border-green-500">
            <p class="text-gray-500 text-sm"><%= __('total_students') %></p>
            <h3 class="text-3xl font-bold text-gray-800"><%= stats.total_students || 0 %></h3>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/teacher/my-classes" class="card-hover bg-white rounded-xl shadow-lg p-6 border border-gray-100">
            <h3 class="text-lg font-semibold text-blue-700 mb-2">
                <i class="fas fa-users mr-2"></i><%= __('my_classes') %>
            </h3>
            <p class="text-gray-600"><%= __('view_assigned_classes_students') %></p>
        </a>
        <a href="/teacher/mark-attendance" class="card-hover bg-white rounded-xl shadow-lg p-6 border border-gray-100">
            <h3 class="text-lg font-semibold text-blue-700 mb-2">
                <i class="fas fa-clipboard-check mr-2"></i><%= __('mark_attendance') %>
            </h3>
            <p class="text-gray-600"><%= __('record_daily_attendance') %></p>
        </a>
        <a href="/teacher/attendance-report" class="card-hover bg-white rounded-xl shadow-lg p-6 border border-gray-100">
            <h3 class="text-lg font-semibold text-blue-700 mb-2">
                <i class="fas fa-chart-bar mr-2"></i><%= __('attendance_reports') %>
            </h3>
            <p class="text-gray-600"><%= __('view_attendance_reports') %></p>
        </a>
        <a href="/teacher/my-timetable" class="card-hover bg-white rounded-xl shadow-lg p-6 border border-gray-100">
            <h3 class="text-lg font-semibold text-blue-700 mb-2">
                <i class="fas fa-calendar-alt mr-2"></i><%= __('my_timetable') %>
            </h3>
            <p class="text-gray-600"><%= __('view_weekly_schedule') %></p>
        </a>
    </div>
</div>
