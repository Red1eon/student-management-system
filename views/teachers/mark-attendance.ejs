<div class="space-y-6 animate-fade-in">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-800"><%= __('mark_attendance') %></h2>
            <p class="text-gray-500"><%= __('mark_attendance_for_assigned_classes') %></p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/teacher/dashboard" class="text-blue-600 hover:text-blue-800 font-medium">
                <i class="fas fa-arrow-left mr-2"></i><%= __('back_to_dashboard') %>
            </a>
            <a href="/teacher/attendance-report" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
                <i class="fas fa-chart-bar mr-2"></i><%= __('view_report') %>
            </a>
        </div>
    </div>

    <!-- Class & Date Selection -->
    <div class="bg-white rounded-xl shadow-lg p-6">
        <form id="selectForm" class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('select_class') %></label>
                <select name="class_id" id="classSelect" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" onchange="this.form.submit()">
                    <option value="">-- <%= __('choose_class') %> --</option>
                    <% classes.forEach(cls => { %>
                        <option value="<%= cls.class_id %>" <%= selectedClass && selectedClass.class_id == cls.class_id ? 'selected' : '' %>>
                            <%= cls.class_name %> <%= cls.section %> 
                            (<%= cls.subjects.map(s => s.subject_name).join(', ') %>)
                        </option>
                    <% }) %>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1"><%= __('date') %></label>
                <input type="date" name="date" id="dateInput" value="<%= selectedDate %>" 
                       max="<%= new Date().toISOString().split('T')[0] %>"
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                       onchange="this.form.submit()">
            </div>
            <div class="flex items-end">
                <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700">
                    <i class="fas fa-search mr-2"></i> <%= __('load_students') %>
                </button>
            </div>
        </form>
    </div>

    <!-- Attendance Marking Table -->
    <% if (students.length > 0) { %>
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div class="p-4 bg-gray-50 border-b flex justify-between items-center">
            <h3 class="font-bold text-gray-800">
                <%= selectedClass.class_name %> <%= selectedClass.section %> - 
                <%= selectedDate %> 
                <span class="text-sm font-normal text-gray-500">(<%= students.length %> <%= __('students') %>)</span>
            </h3>
            <div class="flex space-x-2">
                <button onclick="markAll('present')" class="px-3 py-1 bg-green-100 text-green-700 rounded text-sm hover:bg-green-200"><%= __('all_present') %></button>
                <button onclick="markAll('absent')" class="px-3 py-1 bg-red-100 text-red-700 rounded text-sm hover:bg-red-200"><%= __('all_absent') %></button>
            </div>
        </div>
        
        <form id="attendanceForm">
            <input type="hidden" name="class_id" value="<%= selectedClass.class_id %>">
            <input type="hidden" name="date" value="<%= selectedDate %>">
            
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('roll') %> #</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('student_name') %></th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase"><%= __('status_label') %></th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('remarks') %></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    <% students.forEach((student, index) => { 
                        const existing = existingAttendance.find(a => a.student_id === student.student_id);
                        const currentStatus = existing ? existing.status : '';
                    %>
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            <%= student.roll_number || index + 1 %>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-sm mr-3">
                                    <%= student.first_name[0] %><%= student.last_name[0] %>
                                </div>
                                <div>
                                    <div class="text-sm font-medium text-gray-900"><%= student.first_name %> <%= student.last_name %></div>
                                    <div class="text-xs text-gray-500"><%= student.admission_number %></div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-center">
                            <div class="flex justify-center space-x-2">
                                <label class="cursor-pointer">
                                    <input type="radio" name="attendance[<%= student.student_id %>][status]" value="present" 
                                           <%= currentStatus === 'present' ? 'checked' : '' %>
                                           class="sr-only peer" onchange="updateRowStyle(this)">
                                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-gray-200 text-gray-600 peer-checked:bg-green-500 peer-checked:text-white transition-all"><%= __('status.present') %></span>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="attendance[<%= student.student_id %>][status]" value="absent" 
                                           <%= currentStatus === 'absent' ? 'checked' : '' %>
                                           class="sr-only peer" onchange="updateRowStyle(this)">
                                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-gray-200 text-gray-600 peer-checked:bg-red-500 peer-checked:text-white transition-all"><%= __('status.absent') %></span>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="attendance[<%= student.student_id %>][status]" value="late" 
                                           <%= currentStatus === 'late' ? 'checked' : '' %>
                                           class="sr-only peer" onchange="updateRowStyle(this)">
                                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-gray-200 text-gray-600 peer-checked:bg-yellow-500 peer-checked:text-white transition-all"><%= __('status.late') %></span>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="attendance[<%= student.student_id %>][status]" value="excused" 
                                           <%= currentStatus === 'excused' ? 'checked' : '' %>
                                           class="sr-only peer" onchange="updateRowStyle(this)">
                                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-gray-200 text-gray-600 peer-checked:bg-blue-500 peer-checked:text-white transition-all"><%= __('status.excused') %></span>
                                </label>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <input type="text" name="attendance[<%= student.student_id %>][remarks]" 
                                   value="<%= existing ? existing.remarks : '' %>"
                                   placeholder="<%= __('optional_remarks') %>"
                                   class="w-full px-3 py-1 text-sm border border-gray-300 rounded focus:ring-2 focus:ring-blue-500">
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            
            <div class="p-4 bg-gray-50 border-t flex justify-between items-center">
                <div id="stats" class="text-sm text-gray-600">
                    <%= __('selected') %>: <span id="presentCount" class="font-bold text-green-600">0</span> <%= __('status.present') %>, 
                    <span id="absentCount" class="font-bold text-red-600">0</span> <%= __('status.absent') %>, 
                    <span id="lateCount" class="font-bold text-yellow-600">0</span> <%= __('status.late') %>
                </div>
                <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 font-medium">
                    <i class="fas fa-save mr-2"></i> <%= __('save_attendance') %>
                </button>
            </div>
        </form>
    </div>
    <% } else if (selectedClass) { %>
    <div class="bg-white rounded-xl shadow-lg p-8 text-center text-gray-500">
        <i class="fas fa-users text-4xl mb-4"></i>
        <p><%= __('no_students_in_class') %></p>
    </div>
    <% } %>
</div>

<script>
// Mark all students with same status
function markAll(status) {
    document.querySelectorAll(`input[value="${status}"]`).forEach(radio => {
        radio.checked = true;
        updateRowStyle(radio);
    });
    updateStats();
}

// Update row background based on selection
function updateRowStyle(radio) {
    const row = radio.closest('tr');
    row.classList.remove('bg-green-50', 'bg-red-50', 'bg-yellow-50', 'bg-blue-50');
    
    if (radio.checked) {
        if (radio.value === 'present') row.classList.add('bg-green-50');
        else if (radio.value === 'absent') row.classList.add('bg-red-50');
        else if (radio.value === 'late') row.classList.add('bg-yellow-50');
        else if (radio.value === 'excused') row.classList.add('bg-blue-50');
    }
    updateStats();
}

// Update statistics
function updateStats() {
    const present = document.querySelectorAll('input[value="present"]:checked').length;
    const absent = document.querySelectorAll('input[value="absent"]:checked').length;
    const late = document.querySelectorAll('input[value="late"]:checked').length;
    
    document.getElementById('presentCount').textContent = present;
    document.getElementById('absentCount').textContent = absent;
    document.getElementById('lateCount').textContent = late;
}

// Handle form submission
document.getElementById('attendanceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(e.target);
    const data = {
        class_id: formData.get('class_id'),
        date: formData.get('date'),
        attendance: {}
    };
    
    // Parse attendance data
    formData.forEach((value, key) => {
        const match = key.match(/attendance\[(\d+)\]\[(status|remarks)\]/);
        if (match) {
            const studentId = match[1];
            const field = match[2];
            if (!data.attendance[studentId]) data.attendance[studentId] = {};
            data.attendance[studentId][field] = value;
        }
    });
    
    // Send to server
    try {
        const response = await fetch('/teacher/mark-attendance', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('<%= __('success') %>: ' + result.message);
            location.reload();
        } else {
            alert('<%= __('error') %>: ' + result.error);
        }
    } catch (error) {
        alert('<%= __('failed_save_attendance') %>');
        console.error(error);
    }
});

// Initialize stats on load
updateStats();
</script>
