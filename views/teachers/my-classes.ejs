<div class="space-y-6 animate-fade-in">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-800"><%= __('my_classes') %></h2>
            <p class="text-gray-500"><%= __('view_assigned_classes_students') %></p>
        </div>
        <a href="/teacher/dashboard" class="text-blue-600 hover:text-blue-800 font-medium">
            <i class="fas fa-arrow-left mr-2"></i><%= __('back_to_dashboard') %>
        </a>
    </div>

    <% if (error) { %>
        <div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded-lg">
            <%= error %>
        </div>
    <% } %>

    <% if (classes && classes.length > 0) { %>
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('class_name') %></th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('section') %></th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('room') %></th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= __('actions') %></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    <% classes.forEach(cls => { %>
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 text-sm text-gray-800"><%= cls.class_name %></td>
                            <td class="px-6 py-4 text-sm text-gray-600"><%= cls.section || '-' %></td>
                            <td class="px-6 py-4 text-sm text-gray-600"><%= cls.room_number || '-' %></td>
                            <td class="px-6 py-4">
                                <a href="/teacher/class/<%= cls.class_id %>/students" class="inline-flex items-center px-3 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700">
                                    <i class="fas fa-users mr-2"></i><%= __('view_students') %>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="bg-white rounded-xl shadow-lg p-8 text-center text-gray-500">
            <i class="fas fa-school text-4xl mb-3"></i>
            <h3 class="text-lg font-semibold text-gray-700"><%= __('no_classes_assigned_yet') %></h3>
            <p><%= __('you_have_no_classes_assigned') %></p>
        </div>
    <% } %>
</div>
