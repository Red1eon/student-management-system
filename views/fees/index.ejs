<div class="space-y-6 animate-fade-in">
    <h2 class="text-2xl font-bold text-gray-800">Fee Management</h2>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white rounded-xl shadow-lg p-6">
            <h3 class="text-lg font-bold text-gray-800 mb-4">Recent Transactions</h3>
            <% if (typeof recentPayments !== 'undefined' && recentPayments.length > 0) { %>
                <div class="space-y-3">
                    <% recentPayments.forEach(t => { %>
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
                                <i class="fas fa-check"></i>
                            </div>
                            <div>
                                <p class="font-medium text-gray-800"><%= t.student_name || 'Unknown' %></p>
                                <p class="text-sm text-gray-500"><%= t.fee_name || 'Fee Payment' %></p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="font-bold text-gray-800">$<%= t.amount_paid || 0 %></p>
                            <p class="text-xs text-gray-500"><%= t.payment_date || 'N/A' %></p>
                        </div>
                    </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-gray-500 text-center py-8">No recent transactions</p>
            <% } %>
        </div>
        
        <div class="space-y-6">
            <div class="bg-white rounded-xl shadow-lg p-6">
                <h3 class="text-lg font-bold text-gray-800 mb-4">Fee Summary</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center p-3 bg-green-50 rounded-lg">
                        <span class="text-green-800 font-medium">Collected</span>
                        <span class="text-green-600 font-bold">$<%= typeof stats !== 'undefined' ? (stats.total_collected || 0) : 0 %></span>
                    </div>
                    <div class="flex justify-between items-center p-3 bg-yellow-50 rounded-lg">
                        <span class="text-yellow-800 font-medium">Pending</span>
                        <span class="text-yellow-600 font-bold">$<%= typeof stats !== 'undefined' ? (stats.pending_amount || 0) : 0 %></span>
                    </div>
                    <div class="flex justify-between items-center p-3 bg-blue-50 rounded-lg">
                        <span class="text-blue-800 font-medium">Students Enrolled</span>
                        <span class="text-blue-600 font-bold"><%= typeof stats !== 'undefined' ? (stats.total_students || 0) : 0 %></span>
                    </div>
                </div>
            </div>
            
            <a href="/fees/structure" class="block w-full bg-blue-600 text-white py-3 rounded-lg hover:bg-blue-700 font-semibold text-center shadow-lg">
                <i class="fas fa-layer-group mr-2"></i> Fee Structure
            </a>
            
            <a href="/fees/add?fee_type=tuition&frequency=one-time&return_to=/fees" class="block w-full bg-green-600 text-white py-3 rounded-lg hover:bg-green-700 font-semibold text-center shadow-lg">
                <i class="fas fa-plus mr-2"></i> Add Global Fee
            </a>
             
            <a href="/fees/record" class="block w-full bg-yellow-500 text-white py-3 rounded-lg hover:bg-yellow-600 font-semibold text-center shadow-lg">
                <i class="fas fa-plus mr-2"></i> Record Payment
            </a>
        </div>
    </div>
</div>
