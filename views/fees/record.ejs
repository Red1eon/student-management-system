<div class="max-w-2xl mx-auto animate-fade-in">
    <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="text-2xl font-bold text-gray-800 mb-6"><%= isEdit ? 'Update Fee Payment' : 'Record Fee Payment' %></h2>

        <% if (locals.error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <%= error %>
            </div>
        <% } %>

        <form action="<%= isEdit ? ('/fees/payment/' + payment.payment_id + '/edit') : '/fees/record' %>" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Student *</label>
                <select id="student_id" name="student_id" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500">
                    <option value="">Select Student</option>
                    <% students.forEach(s => { %>
                        <option value="<%= s.student_id %>" <%= String(payment?.student_id || '') === String(s.student_id) ? 'selected' : '' %>><%= s.first_name %> <%= s.last_name %> (<%= s.admission_number %>)</option>
                    <% }) %>
                </select>
            </div>

            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                <p class="text-xs text-blue-800 font-medium">Payment Plan</p>
                <p id="payment_plan_text" class="text-sm text-blue-900">Select a student to view plan and fee structure.</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Fee Structure Item *</label>
                <select id="fee_id" name="fee_id" required data-selected="<%= payment?.fee_id || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500">
                    <option value="">Select Student First</option>
                </select>
                <p id="fee_select_hint" class="text-xs text-gray-500 mt-1">Pick a fee item to apply payment.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Amount Paid *</label>
                    <input type="number" step="0.01" name="amount_paid" required value="<%= payment?.amount_paid || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Payment Date *</label>
                    <input type="date" name="payment_date" required value="<%= payment?.payment_date || new Date().toISOString().split('T')[0] %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Payment Method *</label>
                    <select id="payment_method" name="payment_method" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500">
                        <option value="cash" <%= (payment?.payment_method || 'cash') === 'cash' ? 'selected' : '' %>>Cash</option>
                        <option value="card" <%= payment?.payment_method === 'card' ? 'selected' : '' %>>Card</option>
                        <option value="bank_transfer" <%= payment?.payment_method === 'bank_transfer' ? 'selected' : '' %>>Bank Transfer</option>
                        <option value="online" <%= payment?.payment_method === 'online' ? 'selected' : '' %>>Online</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Transaction ID</label>
                    <input id="transaction_id" type="text" name="transaction_id" value="<%= payment?.transaction_id || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Remarks</label>
                <textarea name="remarks" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-yellow-500"><%= payment?.remarks || '' %></textarea>
            </div>

            <div class="flex justify-end space-x-3">
                <a href="/fees" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</a>
                <button type="submit" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600"><%= isEdit ? 'Update Payment' : 'Record Payment' %></button>
            </div>
        </form>
    </div>
</div>

<script>
    (() => {
        const studentId = document.getElementById('student_id');
        const feeSelect = document.getElementById('fee_id');
        const paymentPlanText = document.getElementById('payment_plan_text');
        const feeSelectHint = document.getElementById('fee_select_hint');
        const paymentMethod = document.getElementById('payment_method');
        const transactionId = document.getElementById('transaction_id');
        if (!paymentMethod || !transactionId || !studentId || !feeSelect || !paymentPlanText || !feeSelectHint) return;

        const updateTransactionRule = () => {
            const isCash = paymentMethod.value === 'cash';
            transactionId.required = !isCash;
        };

        const renderFeeOptions = (fees, selectedFeeId, isFlexible) => {
            feeSelect.innerHTML = '';
            const hasSelectableFee = Array.isArray(fees) && fees.some((fee) => Number.isInteger(Number(fee.fee_id)) && Number(fee.fee_id) > 0);
            const placeholder = document.createElement('option');
            placeholder.value = '';
            placeholder.textContent = hasSelectableFee
                ? 'Select Fee Item'
                : (fees.length ? 'Plan-based structure (Auto assign on save)' : (isFlexible ? 'Flexible Payment (No fixed item required)' : 'No Fee Structure Found'));
            feeSelect.appendChild(placeholder);

            if (isFlexible) {
                const flexibleOption = document.createElement('option');
                flexibleOption.value = '';
                flexibleOption.textContent = 'General Flexible Payment';
                if (!selectedFeeId) flexibleOption.selected = true;
                feeSelect.appendChild(flexibleOption);
            }

            fees.forEach((fee) => {
                const option = document.createElement('option');
                const numericFeeId = Number(fee.fee_id);
                const validFeeId = Number.isInteger(numericFeeId) && numericFeeId > 0;
                option.value = validFeeId ? String(fee.fee_id) : '';
                option.textContent = `${fee.fee_name} - $${Number(fee.amount || 0).toFixed(2)}${fee.due_date ? ` (Due: ${fee.due_date})` : ''}`;
                if (!validFeeId) option.disabled = true;
                if (validFeeId && String(selectedFeeId || '') === String(fee.fee_id)) option.selected = true;
                feeSelect.appendChild(option);
            });

            feeSelect.required = !isFlexible && hasSelectableFee;
            feeSelectHint.textContent = isFlexible
                ? 'Flexible plan: you can record payment without selecting a fixed fee line.'
                : (hasSelectableFee
                    ? 'Pick a fee item to apply payment.'
                    : 'Course payment plan is shown. System will auto-map payment when you submit.');
        };

        const updateStudentFeeContext = async () => {
            const selectedStudentId = studentId.value;
            const selectedFeeId = feeSelect.dataset.selected || '';
            if (!selectedStudentId) {
                paymentPlanText.textContent = 'Select a student to view plan and fee structure.';
                renderFeeOptions([], '', false);
                return;
            }

            try {
                const response = await fetch(`/fees/record/options/${selectedStudentId}`);
                const data = await response.json();
                if (!response.ok) throw new Error(data?.error || 'Failed to load fee options');

                const planLabel = String(data.paymentPlan || 'one_time').replace('_', ' ');
                const planDescription = data.paymentDescription ? ` - ${data.paymentDescription}` : '';
                const allDueDates = Array.isArray(data.allDueDates) ? data.allDueDates : [];
                const deadlineText = allDueDates.length
                    ? ` | Deadlines: ${allDueDates.join(', ')}`
                    : (data.nextDueDate ? ` | Next deadline: ${data.nextDueDate}` : '');
                const overdueText = Number(data.overdueCount || 0) > 0 ? ` | Overdue: ${data.overdueCount}` : '';
                const flexibleText = data.supportsFlexiblePayment ? ' | Flexible: any amount can be recorded' : '';
                paymentPlanText.textContent = `${planLabel.charAt(0).toUpperCase()}${planLabel.slice(1)}${planDescription}${deadlineText}${overdueText}${flexibleText}`;
                renderFeeOptions(Array.isArray(data.fees) ? data.fees : [], selectedFeeId, Boolean(data.supportsFlexiblePayment));
                feeSelect.dataset.selected = '';
            } catch (error) {
                paymentPlanText.textContent = 'Unable to load student fee structure.';
                renderFeeOptions([], '', false);
            }
        };

        studentId.addEventListener('change', updateStudentFeeContext);
        paymentMethod.addEventListener('change', updateTransactionRule);
        updateStudentFeeContext();
        updateTransactionRule();
    })();
</script>
