<div class="space-y-6 animate-fade-in">
  <a href="/students/<%= student.student_id %>" class="text-blue-600 hover:underline inline-block">
    <i class="fas fa-arrow-left mr-2"></i> Back to Student
  </a>

  <h2 class="text-2xl font-bold text-gray-800">Student Fees</h2>

  <div class="bg-white rounded-xl shadow p-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <p class="text-xs text-gray-500">Student</p>
        <p class="font-semibold text-gray-800"><%= student.first_name %> <%= student.last_name %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500">Admission No.</p>
        <p class="font-semibold text-gray-800"><%= student.admission_number %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500">Class</p>
        <p class="font-semibold text-gray-800"><%= student.class_name || 'N/A' %> <%= student.section || '' %></p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-blue-50 rounded-lg p-4"><p class="text-xs text-blue-700">Total Course Fee</p><p class="text-2xl font-bold text-blue-800">$<%= Number(balance?.total || 0).toFixed(2) %></p></div>
    <div class="bg-green-50 rounded-lg p-4"><p class="text-xs text-green-700">Paid</p><p class="text-2xl font-bold text-green-800">$<%= Number(balance?.paid || 0).toFixed(2) %></p></div>
    <div class="bg-red-50 rounded-lg p-4"><p class="text-xs text-red-700">Left to Pay</p><p class="text-2xl font-bold text-red-800">$<%= Number(balance?.balance || 0).toFixed(2) %></p></div>
  </div>
  <div class="bg-amber-50 rounded-lg p-4 -mt-2">
    <p class="text-xs text-amber-700">Payment Deadline</p>
    <p class="text-sm font-semibold text-amber-900"><%= balance?.next_due_date || 'Not set' %></p>
  </div>

  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200"><h3 class="font-semibold text-gray-800">Applicable Fee Structure</h3></div>
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fee</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Payment Plan</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Due Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (Array.isArray(fees) && fees.length > 0) { %>
          <% fees.forEach((fee) => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-800"><%= fee.fee_name %></td>
              <td class="px-6 py-4 text-sm text-gray-800">$<%= Number(fee.amount || 0).toFixed(2) %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= String(fee.payment_plan || balance?.fee_payment_plan || '-').replace('_', ' ') %></td>
              <td class="px-6 py-4 text-sm text-gray-600"><%= fee.due_date || '-' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="4" class="px-6 py-8 text-center text-gray-500">No fee structure records</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200"><h3 class="font-semibold text-gray-800">Payment History</h3></div>
    <table class="w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Fee</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Method</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Receipt</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% if (Array.isArray(payments) && payments.length > 0) { %>
          <% payments.forEach((payment) => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-700"><%= payment.payment_date || '-' %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= payment.fee_name || '-' %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= payment.payment_method || '-' %></td>
              <td class="px-6 py-4 text-sm text-gray-800">$<%= Number(payment.amount_paid || 0).toFixed(2) %></td>
              <td class="px-6 py-4 text-sm">
                <% if (payment.receipt_number) { %>
                  <a href="/fees/receipt/<%= payment.receipt_number %>" class="text-blue-600 hover:text-blue-800"><%= payment.receipt_number %></a>
                <% } else { %>
                  <span class="text-gray-400">-</span>
                <% } %>
              </td>
              <td class="px-6 py-4 text-sm">
                <a href="/fees/payment/<%= payment.payment_id %>/edit" class="text-blue-600 hover:text-blue-800">Edit</a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">No payments recorded</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
